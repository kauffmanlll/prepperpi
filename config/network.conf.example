# Example network configuration for PrepperPi
# Copy to config/network.conf and edit values.
# Variable names below must match what scripts/install.sh reads — do not rename.

# Access Point (hostapd) settings
SSID="PrepperPi"
PASSPHRASE="CHANGE_ME_STRONG_PASSWORD"
COUNTRY="US"
WIFI_INTERFACE="wlan0"

# Static IP / subnet for the AP interface
SUBNET="10.10.0.0/24"
PI_IP="10.10.0.1"

# DHCP range handed out by dnsmasq
DHCP_RANGE_START="10.10.0.50"
DHCP_RANGE_END="10.10.0.150"
