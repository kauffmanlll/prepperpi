// Allow the unprivileged prepperpi service account to start the
// content-update unit from the web UI without a password prompt.
polkit.addRule(function(action, subject) {
    if (action.id == "org.freedesktop.systemd1.manage-units" &&
        subject.user == "prepperpi") {
        var unit = action.lookup("unit");
        if (unit == "prepperpi-update.service") {
            return polkit.Result.YES;
        }
    }
});
